<?xml version="1.0" encoding="utf-8"?>

    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        tools:context=".ui.detail.StudentDetailFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/backgroundcolor">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stud_profile"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/lightBlack"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/info"
                android:textSize="14sp"
                android:textColor="@color/courseTxtColor"
                android:layout_marginTop="4dp"/>

            <!-- Profile Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/imgStudentPhoto"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_gravity="center_horizontal"
                        android:src="@drawable/ic_person_placeholder"
                        android:scaleType="centerCrop"
                        android:background="@drawable/circle_bg"
                        android:clipToOutline="true"
                        android:outlineProvider="background"
                        android:contentDescription="Student photo" />


                    <!-- Name -->
                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/name_txt"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_gravity="center"
                        android:layout_marginTop="12dp"/>

                    <!-- Email -->
                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/email_txt"
                        android:textColor="@color/darkGrey"
                        android:layout_gravity="center"
                        android:layout_marginTop="4dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/lightGrey"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Course -->
                    <TextView
                        android:text="@string/course_txt"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textStyle="bold"
                        android:textColor="@color/txtColor"/>

                    <TextView
                        android:id="@+id/tvCourse"
                        android:layout_marginTop="4dp"
                        android:text="--"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"/>

                    <!-- Phone -->
                    <TextView
                        android:layout_marginTop="12dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="@string/phone_txt"
                        android:textStyle="bold"
                        android:textColor="@color/txtColor"/>

                    <TextView
                        android:id="@+id/tvPhone"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="--"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>
            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEdit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/edit_txt"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDelete"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="@string/delete_txt"
                    android:backgroundTint="@color/lightRed"/>
            </LinearLayout>

            <!-- View Attendance button — full width, below Edit/Delete -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewAttendance"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="@string/view_report"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/nameTxtColor"
                app:cornerRadius="12dp"
                app:icon="@null"/>

        </LinearLayout>

    </ScrollView>