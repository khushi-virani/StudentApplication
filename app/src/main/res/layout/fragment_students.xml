<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.students.StudentsFragment">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/backgroundcolor">

        <!--  Toolbar added here — anchored to top of screen -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:layout_alignParentTop="true"
            android:background="@color/orange"
            app:title="@string/app_name"
            app:titleTextColor="@color/white" />

        <LinearLayout
            android:id="@+id/layoutTop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/toolbar"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Search Bar -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search students..."
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawableStart="@android:drawable/ic_menu_search"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Sort Buttons Row -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/all_chip"
                        android:layout_marginEnd="8dp"
                        app:chipBackgroundColor="@color/orange"
                        android:textColor="@color/white"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/aToz_txt"
                        android:layout_marginEnd="8dp"
                        app:chipBackgroundColor="@color/chipDefault"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipCourse"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/course_txt"
                        android:layout_marginEnd="8dp"
                        app:chipBackgroundColor="@color/chipDefault"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDateAsc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/old_stud"
                        android:layout_marginEnd="8dp"
                        app:chipBackgroundColor="@color/chipDefault"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDateDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/new_stud"
                        app:chipBackgroundColor="@color/chipDefault"/>

                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>

        <!-- Student List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvStudents"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/layoutTop"
            android:paddingBottom="16dp"
            android:clipToPadding="false"/>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎓"
                android:textSize="64sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Students Found"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/nameTxtColor"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap the + button to add your first student"
                android:textColor="@color/grey"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddFirstStudent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Student"
                android:layout_marginTop="20dp"
                app:backgroundTint="@color/orange"
                app:cornerRadius="12dp"/>

        </LinearLayout>

    </RelativeLayout>
</FrameLayout>